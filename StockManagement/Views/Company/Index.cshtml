@model Company
@{
    ViewData["PageTitle"] = "Compagnie";
    ViewData["Title"] = ViewData["PageSubTitle"] = "Informations de la compagnie";
}

@if (TempData["StatusMessage"] != null)
{
    <div class="alert alert-info">@TempData["StatusMessage"]</div>
}

<div class="card shadow">
    <form asp-action="@(Model.Id == 0 ? "Create" : "Edit")" method="post" enctype="multipart/form-data">
        <input type="hidden" asp-for="Id" />
        <div class="card-body">
            <div class="row">
                <div class="col-md-4">
                    <label class="form-label required">Logo</label>
                    <div class="card mb-3">
                        <div class="card-body text-center">
                            <img id="logo" class="img-fluid"
                                 src="@(Model.Logo != null ? $"data:image/*;base64,{Convert.ToBase64String(Model.Logo)}" : "/img/logo.png")"
                                 style="min-width:250px; max-width: 250px; min-height: 250px; max-height: 250px;" />
                        </div>
                        <div class="card-footer">
                            <input name="logoFile" type="file" accept="image/*" class="form-control text-truncate" onchange="document.getElementById('logo').src = window.URL.createObjectURL(this.files[0])" />
                        </div>
                    </div>
                </div>
                <div class="col-md-8">
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label asp-for="Name" class="form-label required"></label>
                            <input asp-for="Name" class="form-control" required />
                        </div>
                        <div class="col-md-6 mb-3">
                            <label asp-for="PhoneNumber" class="form-label"></label>
                            <input asp-for="PhoneNumber" class="form-control" />
                        </div>
                        <div class="col-md-12 mb-3">
                            <label asp-for="Address" class="form-label"></label>
                            <textarea asp-for="Address" class="form-control"></textarea>
                        </div>
                    </div>
                </div>
            </div>
            <button type="submit" class="btn btn-primary w-100">
                <i class="fa fa-save"></i> Enregistrer
            </button>
        </div>
    </form>
</div>
